<section class="shop-config">
  <div class="center dc-newspaper-subhead">{{localize "dc.shop.tab.header"}}</div>
  <p class="typed-small center">{{localize "dc.shop.tab.hint"}}</p>

  <div class="shop-enable-row flexrow" style="margin: 12px 0; align-items: center; gap: 8px;">
    <label>{{localize "dc.shop.enable.label"}}</label>
    <button type="button" data-action="shopToggleEnable">
      {{#if shop.enabled}}{{localize "dc.shop.enabled"}}{{else}}{{localize "dc.shop.disabled"}}{{/if}}
    </button>
  </div>

  <div class="shop-haggle-tn flexrow" style="margin: 12px 0; align-items: center; gap: 8px; flex-wrap: wrap;">
    <label>{{localize "dc.shop.haggle_tn"}}</label>
    <input type="number" class="shop-supply-input" data-action="modifyShopField" data-field="haggle_tn" value="{{shop.haggle_tn}}" min="1" />
    <label>{{localize "dc.shop.merchant_cash"}}</label>
    <input type="number" class="shop-supply-input" data-action="modifyShopField" data-field="cash" value="{{shop.cash}}" min="-1" title="{{localize "dc.shop.unlimited_hint"}}" />
    <label>{{localize "dc.shop.sell_ratio"}}</label>
    <input type="number" class="shop-supply-input" data-action="modifyShopField" data-field="sell_ratio" value="{{shop.sell_ratio}}" min="0" max="1" step="0.05" />
  </div>

  {{#if shop_customers.length}}
  <h4 class="center dc-header">{{localize "dc.shop.customers"}}</h4>
  <table>
    <tr>
      <th>{{localize "dc.shared.name"}}</th>
      <th>{{localize "dc.shop.opinion"}}</th>
      <th>{{localize "dc.shop.price_modifier"}}</th>
    </tr>
    {{#each shop_customers as |row|}}
    <tr>
      <td class="left">{{row.name}}</td>
      <td class="center">
        <input type="number" class="shop-supply-input" data-action="modifyShopCustomer" data-actor-id="{{row.actor_id}}" data-field="opinion" value="{{row.opinion}}" />
      </td>
      <td class="center">
        <input type="number" class="shop-supply-input" data-action="modifyShopCustomer" data-actor-id="{{row.actor_id}}" data-field="price_modifier_pct" value="{{row.price_modifier_pct}}" />%
      </td>
    </tr>
    {{/each}}
  </table>
  {{/if}}

  <div class="scroll-container">
    <div class="scroll shop-catalog-gm" data-scroll-id="shop-catalog-gm">
      {{> "modules/smith-and-robards/templates/partials/shop_category.hbs"
        header="dc.gear.ammo" items=shop_catalog.ammo}}
      {{> "modules/smith-and-robards/templates/partials/shop_category.hbs"
        header="dc.gear.armour" items=shop_catalog.armour}}
      {{> "modules/smith-and-robards/templates/partials/shop_category.hbs"
        header="dc.gear.melee" items=shop_catalog.melee}}
      {{> "modules/smith-and-robards/templates/partials/shop_category.hbs"
        header="dc.gear.ranged" items=shop_catalog.ranged}}
      {{> "modules/smith-and-robards/templates/partials/shop_category.hbs"
        header="dc.gear.thrown" items=shop_catalog.thrown}}
      {{> "modules/smith-and-robards/templates/partials/shop_category.hbs"
        header="dc.gear.explosives" items=shop_catalog.explosives}}
      {{> "modules/smith-and-robards/templates/partials/shop_category.hbs"
        header="dc.gear.misc" items=shop_catalog.misc}}
      {{> "modules/smith-and-robards/templates/partials/shop_category.hbs"
        header="dc.gear.goods" items=shop_catalog.goods}}
      {{> "modules/smith-and-robards/templates/partials/shop_category.hbs"
        header="dc.gear.services" items=shop_catalog.services}}
    </div>
  </div>
</section>