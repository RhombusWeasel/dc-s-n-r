<div class="deadlands-sheet newspaper-sheet npc-shop flexcol">
  {{#if loading}}
  <p class="center" style="padding: 2em;">{{localize "dc.shop.loading"}}</p>
  {{else}}
  <div class="center dc-header">{{shop_name}}</div>

  {{#if has_buyer}}
  <div class="shop-buyer-row flexrow">
    <label>{{localize "dc.shop.buyer"}}</label>
    <select class="shop-buyer-select">
      {{#each buyers as |b|}}
      <option value="{{b.id}}" {{#if b.selected}}selected{{/if}}>{{b.name}}</option>
      {{/each}}
    </select>
  </div>
  <div class="center typed-small">
    {{localize "dc.shop.price_modifier"}}: {{price_modifier_pct}}% —
    {{localize "dc.shop.opinion"}}: {{opinion}}
  </div>
  <div class="center" style="margin: 8px 0;">
    <button type="button" data-action="haggle">
      {{localize "dc.shop.haggle"}} (TN {{haggle_tn}})
    </button>
  </div>
  {{else}}
  <p class="center">{{localize "dc.shop.errors.no_buyer"}}</p>
  {{/if}}

  {{#if has_buyer}}
  <div class="shop-barter-row flexrow">
    {{> "modules/smith-and-robards/templates/partials/shop_barter_column.hbs"
      header_key="dc.shop.player"
      cash=player_cash
      cash_label_key="dc.shop.cash"
      items=player_items
      side="player"
      scroll_id="shop-player"}}
    {{> "modules/smith-and-robards/templates/partials/shop_barter_trade.hbs"}}
    {{> "modules/smith-and-robards/templates/partials/shop_barter_column.hbs"
      title=shop_name
      cash=merchant_cash
      cash_label_key="dc.shop.merchant_cash"
      items=merchant_items
      side="merchant"
      scroll_id="shop-merchant"}}
  </div>
  {{/if}}

  <div class="center shop-barter-actions">
    <button type="button" data-action="close">{{localize "dc.dialog.cancel"}}</button>
  </div>
  {{/if}}
</div>